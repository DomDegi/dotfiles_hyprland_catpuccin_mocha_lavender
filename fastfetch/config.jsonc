{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "type": "builtin",
    "source": "arch",
    "color": {
      "1": "38;2;180;190;254", // Catppuccin Mocha Lavender
      "2": "38;2;203;166;247"  // Catppuccin Mocha Mauve (for the secondary logo color)
    },
    "padding": {
      "top": 1,
      "left": 2,
      "right": 4
    }
  },
  "display": {
    "separator": " • ",
    "color": "38;2;180;190;254" // Made the separator Lavender too!
  },
  "modules": [
    "break",     // Prima riga vuota per abbassare il testo
    "break",     // Seconda riga vuota (aggiungine altri se vuoi scendere ancora)
    {
      "type": "os",
      "key": "",
      "keyColor": "38;2;180;190;254" // You can use RGB for keys too!
    },
    {
      "type": "uptime",
      "key": "",
      "keyColor": "yellow"
    },
    {
      "type": "packages",
      "key": "",
      "keyColor": "blue"
    },
    {
      "type": "wm",
      "key": "",
      "keyColor": "magenta"
    },
    {
      "type": "terminal",
      "key": "",
      "keyColor": "green"
    },
    {
      "type": "shell",
      "key": "",
      "keyColor": "blue"
    },
    {
      "type": "memory",
      "key": "󰑭",
      "keyColor": "yellow"
    }
  ]
}
